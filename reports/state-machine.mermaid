%% auth.ts :: error_recovery
stateDiagram-v2
  [*] --> attempt
  state caught <<error>>
  attempt --> success : no error
  attempt --> caught : catch
  success --> [*]

%% config.ts :: error_recovery
stateDiagram-v2
  [*] --> attempt
  state caught <<error>>
  attempt --> success : no error
  attempt --> caught : catch
  caught --> fallback : fallback
  fallback --> success : complete
  success --> [*]

